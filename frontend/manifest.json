{
  "manifest_version": 3,
  "name": "Hansung-Link",
  "version": "0.1.0",
  "description": "AI academic assistant chatbot for Hansung University students.",
  "permissions": ["tabs", "activeTab", "storage"],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*",
    "https://info.hansung.ac.kr/*",
    "https://learn.hansung.ac.kr/*",
    "https://www.hansung.ac.kr/*",
    "https://hansung.ac.kr/*",
    "https://hsportal.hansung.ac.kr/*"
  ],
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Open Hansung-Link"
  },
  "content_scripts": [
    {
      "matches": [
        "https://info.hansung.ac.kr/*",
        "https://learn.hansung.ac.kr/*",
        "https://www.hansung.ac.kr/*",
        "https://hansung.ac.kr/*",
        "https://hsportal.hansung.ac.kr/*"
      ],
      "js": ["assets/content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["sidepanel.html", "assets/*"],
      "matches": [
        "https://info.hansung.ac.kr/*",
        "https://learn.hansung.ac.kr/*",
        "https://www.hansung.ac.kr/*",
        "https://hansung.ac.kr/*",
        "https://hsportal.hansung.ac.kr/*"
      ]
    }
  ]
}
